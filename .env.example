# For local development only. During scoring, we provide our own keys.
# You only need the key(s) for the provider your submission uses.
# Use these exact variable names so your code works with both your keys and ours.
OPENAI_API_KEY=your-openai-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here

# Optional: override defaults
# PRIMARY_PROVIDER=anthropic
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# OPENAI_MODEL=gpt-4o-mini
# TEMPERATURE=0.1
# MAX_TOKENS=2048
# MAX_RETRIES=2
# REQUEST_TIMEOUT=25
